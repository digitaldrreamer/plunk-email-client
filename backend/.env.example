# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/reclear

# JWT secret for auth tokens — use a long random string in production
JWT_SECRET=change-me-in-production

# Mistral AI — get from https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# Google Safe Browsing API — get from https://developers.google.com/safe-browsing/v4/get-started
GOOGLE_SAFE_BROWSING_API_KEY=

# Seeded admin account (used only on first boot when no users exist)
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@reclear.io
ADMIN_PASSWORD=changeme123

# Plunk — get from https://app.useplunk.com/settings/api
PLUNK_SECRET_KEY=sk_...
PLUNK_FROM_EMAIL=hello@reclear.io
PLUNK_API_BASE=https://next-api.useplunk.com

# Bearer token to validate inbound email webhooks from Plunk
PLUNK_INBOUND_SECRET=your-inbound-secret

# Bearer token to validate bounce/complaint workflow webhooks from Plunk
PLUNK_WEBHOOK_SECRET=your-webhook-secret

# Allowed origin for CORS
FRONTEND_URL=http://localhost:3000

PORT=3001
